# FitFlow 7 — Phase 1 (accounts + cloud sync) configuration.
#
# Copy to `.env` for local `vercel dev`, and set the same keys in the Vercel
# project (Settings -> Environment Variables) for production. Until these are
# set the API returns "not configured" and the app stays fully local-only —
# nothing about the signed-out experience changes.
#
# See SETUP_SYNC.md for step-by-step account creation.

# --- Turso (libSQL) database ---------------------------------------------
# Create a DB:  turso db create fitflow7
# URL:          turso db show fitflow7 --url
# Token:        turso db tokens create fitflow7
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Session signing secret ----------------------------------------------
# Any long random string. Generate: openssl rand -base64 32
SESSION_SECRET=

# --- GitHub OAuth (optional if you only use Google) ----------------------
# Create at https://github.com/settings/developers -> New OAuth App.
# Authorization callback URL: https://<your-app>/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth (optional if you only use GitHub) ----------------------
# Create at https://console.cloud.google.com/apis/credentials -> OAuth client ID
# (Web application). Authorized redirect URI: https://<your-app>/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional: pin the public base URL used to build OAuth redirect URIs --
# Leave blank to derive it from request headers (works on Vercel). Set it if
# you hit redirect-URI mismatches, e.g. https://fitflow7.vercel.app
APP_URL=
